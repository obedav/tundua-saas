# ============================================================================
# TUNDUA SAAS - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
#
# IMPORTANT: These values will be used in production (Vercel)
# Add these variables in Vercel dashboard under Settings → Environment Variables
#
# ============================================================================

# ============================================================================
# API CONFIGURATION (REQUIRED)
# ============================================================================
# Backend API URL - your deployed PHP backend
NEXT_PUBLIC_API_URL=https://api.tundua.com/api

# Frontend App URL - your production domain
NEXT_PUBLIC_APP_URL=https://tundua.com

# ============================================================================
# SENTRY ERROR TRACKING (RECOMMENDED)
# ============================================================================
# Real-time error monitoring and tracking
# Sign up at https://sentry.io for free tier
# Leave empty to disable for now
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=tundua-frontend
SENTRY_AUTH_TOKEN=

# ============================================================================
# POSTHOG ANALYTICS (RECOMMENDED)
# ============================================================================
# Privacy-friendly product analytics
# Sign up at https://posthog.com for free tier (1M events/month)
# Leave empty to disable for now
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================================
# PUSHER CONFIGURATION (REQUIRED FOR REAL-TIME FEATURES)
# ============================================================================
# Real-time notifications using Pusher
# Sign up at https://pusher.com and get your credentials
# Cluster: eu (Europe - closest to Nigeria)
NEXT_PUBLIC_PUSHER_KEY=9482b5b67b0b2822a14d
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ============================================================================
# STRIPE PAYMENTS (PRODUCTION)
# ============================================================================
# Stripe payment processing - Nigerian Naira (NGN) support
# Get your live keys from https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=[YOUR_STRIPE_LIVE_PUBLIC_KEY]

# Note: STRIPE_SECRET_KEY should NEVER be in frontend .env
# It's only used in backend .env for server-side processing

# ============================================================================
# PAYSTACK PAYMENTS (PRIMARY FOR NIGERIA)
# ============================================================================
# Paystack is preferred for Nigerian transactions (lower fees, local settlement)
# Get your live keys from https://dashboard.paystack.com
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_15ad1cce4b9e5fd4d9a48f127ee4296cec7dc759

# ============================================================================
# AI DOCUMENT ASSISTANT (OPTIONAL - FUTURE FEATURE)
# ============================================================================

# Leave empty to disable AI features
ANTHROPIC_API_KEY=

# Alternative: OpenAI GPT-4
# Leave empty to disable
OPENAI_API_KEY=

# ============================================================================
# GOOGLE OAUTH (OPTIONAL - PHASE 2)
# ============================================================================
# Google Sign-In integration
# Leave empty to disable for Phase 1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================================
# APP CONFIGURATION
# ============================================================================
# Application name (for emails, notifications, etc.)
NEXT_PUBLIC_APP_NAME=Tundua Study Abroad

# ============================================================================
# VERCEL DEPLOYMENT NOTES
# ============================================================================
# 1. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 2. Add all variables above (one by one)
# 3. Set "Environment" to "Production"
# 4. Click "Save"
# 5. Redeploy your application
#
# IMPORTANT: Never commit this file with real credentials to git!
# This file is for reference only when setting up Vercel environment variables
# ============================================================================

# ============================================================================
# QUICK START CHECKLIST
# ============================================================================
# Before deploying to Vercel, ensure you have:
# ✅ Updated NEXT_PUBLIC_API_URL to your backend URL
# ✅ Added Pusher credentials (for real-time notifications)
# ✅ Added Stripe live publishable key
# ✅ Added Paystack live public key
# ✅ Optional: Sentry DSN for error tracking
# ✅ Optional: PostHog key for analytics
# ============================================================================
